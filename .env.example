# Resend — API key para el envío de correos del formulario de contacto
# Generar en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx

# Destinatario de los mensajes del formulario
CONTACT_TO_EMAIL=enzo.norese@gmail.com

# Remitente. Sin dominio verificado usa el sandbox de Resend (onboarding@resend.dev).
# Con dominio verificado: "Portfolio <contacto@tudominio.dev>".
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
